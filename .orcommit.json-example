{
    "providers": {
        "openrouter": {
            "baseUrl": "https://openrouter.ai/api/v1",
            "timeout": 60000,
            "apiKey": "xxxxx",
            "model": "arcee-ai/trinity-large-preview:free"
        },
        "openai": {
            "baseUrl": "https://api.openai.com/v1",
            "timeout": 60000
        }
    },
    "preferences": {
        "defaultProvider": "openrouter",
        "maxTokens": 500,
        "temperature": 0.8,
        "autoConfirm": false,
        "language": "en",
        "commitFormat": "conventional",
        "maxCommitLength": 800
    },
    "version": "1.0.0"
}
