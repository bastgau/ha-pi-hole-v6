#!/bin/bash

# Colors
BLUE='\033[34m'
GRAY='\033[0;90m'
GREEN='\033[32m'
MAGENTA='\033[0;35m'
PURPLE='\033[1;35m'
RED='\033[31m'
YELLOW='\033[33m'
NC='\033[0m' # No Color

PROJECT="$PROJECT_NAME"

cd "$(dirname "$0")/.."

echo -e "\n${YELLOW}> Determinate files changed :${NC}\n"

export files="$(find /workspaces/${PROJECT}/custom_components -name '*.py')"

if [ -z "$files" ] ; then
  echo "No python file changed.\n"
  exit
fi

printf "%s\n" $files

exit_code=0

echo -e "\n${YELLOW}> Lint with Ruff :${NC}\n"
prek run ruff-check --files $files
ruff_exit=$?
if [ $ruff_exit -eq 0 ]; then
  echo -e "\n${BLUE}[ruff]${NC} ${GREEN}✓ Done.${NC}"
else
  echo -e "\n${BLUE}[ruff]${NC} ${RED}✗ Failed.${NC}"
  exit_code=1
fi

echo -e "\n${YELLOW}> Lint with Pylint :${NC}"

pylint_files=$(echo "$files" | grep -v '^tests.*')

if [ -z "$pylint_files" ] ; then
  echo -e "\n${BLUE}[config]${NC} ${PURPLE}✗ Only test files changed. End.${NC}\n"
  exit $exit_code
else
  pylint_output=$(pylint $pylint_files 2>&1)
  pylint_exit=$?
  echo "$pylint_output" | grep -v "^-\{10,\}$"
  rating=$(echo "$pylint_output" | grep "Your code has been rated")
  score=""
  if [ -n "$rating" ]; then
    score=$(echo "$rating" | grep -oP '\d+\.\d+/\d+' | head -1)
  fi
  if [ $pylint_exit -eq 0 ]; then
    echo -e "\n${BLUE}[pylint]${NC} Score: ${score} ${GREEN}✓ Done.${NC}"
  else
    echo -e "\n${BLUE}[pylint]${NC} Score: ${score} ${RED}✗ Failed.${NC}"
    exit_code=1
  fi
fi

echo -e "\n${YELLOW}> Lint with Pyright :${NC}\n"

pyright $pylint_files
pyright_exit=$?
if [ $pyright_exit -eq 0 ]; then
  echo -e "\n${BLUE}[pyright]${NC} ${GREEN}✓ Done.${NC}\n"
else
  echo -e "\n${BLUE}[pyright]${NC} ${RED}✗ Failed.${NC}\n"
  exit_code=1
fi

exit $exit_code
